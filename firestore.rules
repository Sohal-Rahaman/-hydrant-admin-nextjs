rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if user is admin
    function isAdmin() {
      return request.auth != null && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true ||
        request.auth.token.phone_number in ['+917908013185', '+917001397070', '+919832036181', '+911111111111']
      );
    }

    // Helper function to check if user is a delivery partner (Army member)
    function isArmyMember() {
      return request.auth != null && exists(/databases/$(database)/documents/army/$(request.auth.uid));
    }
    
    // Allow users to read and write their own user data, admins have full access
    match /users/{userId} {
      allow read: if request.auth != null && (request.auth.uid == userId || isAdmin() || isArmyMember());
      allow write, update, delete: if request.auth != null && (request.auth.uid == userId || isAdmin());
      // Added a separate read rule for admins/partners to ensure they can list users
      allow list: if request.auth != null && (isAdmin() || isArmyMember());
    }
    
    // Account deletion requests collection - admins have full access
    match /account_deletion_requests/{requestId} {
      allow read, write: if request.auth != null && request.auth.uid == resource.data.userId;
      allow read, write, update, delete, list: if request.auth != null && isAdmin();
    }
    
    // Allow users to read and write their own orders, but admins can read all
    match /orders/{orderId} {
      allow read: if request.auth != null && 
        (resource == null || resource.data.userId == request.auth.uid || isAdmin() || isArmyMember());
      allow write, update: if request.auth != null && 
        (resource == null || resource.data.userId == request.auth.uid || isAdmin() || isArmyMember());
    }
    
    // Allow users to read and write their own addresses, but admins can read all
    match /addresses/{addressId} {
      allow read: if request.auth != null && 
        (resource == null || resource.data.userId == request.auth.uid || isAdmin() || isArmyMember());
      allow write, update, delete: if request.auth != null && 
        (resource == null || resource.data.userId == request.auth.uid || isAdmin());
    }
    
    // Allow users to read and write their own cart items, but admins can read all
    match /cart/{cartId} {
      allow read: if request.auth != null && 
        (resource == null || resource.data.userId == request.auth.uid || isAdmin());
      allow write, update, delete: if request.auth != null && 
        (resource == null || resource.data.userId == request.auth.uid || isAdmin());
    }
    
    // Allow users to read and write their own subscriptions, but admins can read all
    match /subscriptions/{subscriptionId} {
      allow read: if request.auth != null && 
        (resource == null || resource.data.userId == request.auth.uid || isAdmin() || isArmyMember());
      allow write, update: if request.auth != null && 
        (resource == null || resource.data.userId == request.auth.uid || isAdmin() || isArmyMember());
    }
    
    // Allow read access to counters for order ID generation
    match /counters/{counterId} {
      allow read, write: if request.auth != null;
    }
    
    // Allow read access to products (public data)
    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin(); // Only admins should write products
    }
    
    // Dashboard stats collection - allow admins to read/write, regular users to read
    match /dashboard_stats/{document} {
      allow read: if request.auth != null; // All authenticated users can read dashboard stats
      allow write: if isAdmin(); // Only admins can write dashboard stats
    }
    
    // Hold jars collection - allow users to read/write their own, admins can access all
    match /holdJars/{document} {
      allow read: if request.auth != null && 
        (resource == null || resource.data.userId == request.auth.uid || isAdmin() || isArmyMember());
      allow write, update, delete: if request.auth != null && 
        (resource == null || resource.data.userId == request.auth.uid || isAdmin() || isArmyMember());
    }
    
    // Admin notifications collection - only admins can read/write
    match /admin_notifications/{document} {
      allow read, write, update, delete, list: if isAdmin();
    }
    
    // Pro Model: Jars collection - admins have full access
    match /jars/{jarId} {
      allow read, write, update, delete, list: if isAdmin() || isArmyMember();
    }
    
    // Pro Model: Pro Plans collection - readable by all, writable by admins
    match /proPlans/{planId} {
      allow read: if request.auth != null || true; // Public or authenticated can read plans
      allow write, update, delete: if isAdmin();
    }
    
    // Pro Model: Pro Memberships collection - users can read their own, admins full access
    match /pro_memberships/{userId} {
      allow read: if request.auth != null && (request.auth.uid == userId || isAdmin() || isArmyMember());
      allow write, update, delete: if isAdmin();
    }
    
    // ─── ADMIN & DEV COLLECTIONS ───────────────────────────────────────────
    
    // Developer logs - only admins can access
    match /dev_error_logs/{document} { allow read, write, list: if isAdmin(); }
    match /dev_payment_logs/{document} { allow read, write, list: if isAdmin(); }
    match /dev_api_logs/{document} { allow read, write, list: if isAdmin(); }
    match /dev_order_failures/{document} { allow read, write, list: if isAdmin(); }
    match /dev_security_logs/{document} { allow read, write, list: if isAdmin(); }
    match /dev_notification_logs/{document} { allow read, write, list: if isAdmin(); }
    match /dev_cart_activity/{document} { allow read, write, list: if isAdmin(); }
    
    // Admin activities feed
    match /admin_activities/{document} {
      allow read, list: if isAdmin();
      allow write: if request.auth != null; // Allow logging from app/functions
    }
    
    // Staff management
    match /admins/{document} {
      allow read, list: if request.auth != null; // Needed for AuthContext check
      allow write, update, delete: if isAdmin();
    }
    
    // Army members (delivery partners)
    match /army/{document} {
      allow read, list: if request.auth != null;
      allow write, update, delete: if isAdmin();
    }
  }
}